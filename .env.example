# Nairamart Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Database
DATABASE_URL="file:./db/nairamart.db"

# NextAuth (uncomment and configure for production)
# NEXTAUTH_URL="https://nairamart.ng"
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# App
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://nairamart.ng"

# Redis (for rate limiting and sessions in production)
# REDIS_URL="redis://localhost:6379"

# Payment Gateway (Paystack)
# PAYSTACK_PUBLIC_KEY=""
# PAYSTACK_SECRET_KEY=""
# PAYSTACK_WEBHOOK_SECRET=""

# Email (Resend/SendGrid)
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""

# AWS S3 (for image uploads)
# S3_BUCKET=""
# S3_REGION="af-south-1"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Logging
# LOG_LEVEL="info"